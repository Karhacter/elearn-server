{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  },

  "AllowedHosts": "*",
  "Jwt": {
    "Key": "",
    "Issuer": "elearn-server",
    "Audience": "elearn-client",
    "ExpireDays": 7,
    "RefreshTokenExpireDays": 30
  },
  "AuthSecurity": {
    "EmailVerificationExpireHours": 24,
    "RequireEmailVerification": true
  },
  "App": {
    "FrontendBaseUrl": ""
  },
  "Smtp": {
    "Host": "",
    "Port": "587",
    "Username": "",
    "Password": "",
    "FromEmail": "",
    "FromName": "E-Learn",
    "EnableSsl": "true"
  },
  "Ollama": {
    "BaseUrl": "http://localhost:11434/",
    "Model": "llama3.2:3b",
    "EnableRecommendations": true
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  }
}

